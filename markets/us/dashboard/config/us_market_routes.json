    "EODHD fallback"
  ],
  "incremental_cache_policy": {
    "bootstrap_once": "Stooq d_us_txt.zip after browser/CAPTCHA download, normalized to the last 420 daily bars per symbol",
    "daily_append": "Stooq current date snapshot first, Yahoo completed-session batch second, EODHD unresolved symbols only",
    "full_history_refetch_only_for": ["new_symbol", "missing_bar_gap", "corporate_action", "provider_conflict", "schema_migration"],
    "compute_policy": "derive all AURORA indicators and scan memberships locally from one cached series per symbol"
  }
